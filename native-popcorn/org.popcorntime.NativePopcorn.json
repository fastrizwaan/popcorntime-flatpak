{
  "app-id": "org.popcorntime.NativePopcorn",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "native-popcorn",
  "finish-args": [
    "--share=ipc",
    "--share=network",
    "--socket=x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=xdg-run/tmp:rw",
    "--filesystem=/var/tmp:rw",
    "--talk-name=org.freedesktop.Flatpak"
  ],
  "modules": [
    {
      "name": "nodejs",
      "buildsystem": "simple",
      "build-commands": [
        "cp -r * /app/"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://nodejs.org/dist/v20.11.1/node-v20.11.1-linux-x64.tar.xz",
          "sha256": "d8dab549b09672b03356aa2257699f3de3b58c96e74eb26a8b495fbdc9cf6fbe"
        }
      ]
    },
    {
      "name": "native-popcorn",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ],
      "post-install": [
        "echo '#!/bin/sh' > /app/bin/mpv",
        "echo 'exec flatpak-spawn --host flatpak run io.mpv.Mpv \"$@\"' >> /app/bin/mpv",
        "chmod +x /app/bin/mpv"
      ]
    }
  ]
}
